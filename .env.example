# Quant-OS secrets & overrides. Copy to `.env` (git-ignored).
# Env vars use the QUANTLAB_ prefix and OVERRIDE config.yaml.

# QUANTLAB_DATA_DIR=D:/Backtests/data
# QUANTLAB_IDEAS_DIR=D:/Backtest Ideas
# QUANTLAB_LLM_BACKEND=llamacpp

# API keys may also live as .<service>.key files in keys_dir (git-ignored via *.key),
# which the existing quantlab.fundamental_data.read_api_key() already resolves:
#   .fred.key  .eia.key  .nass.key  .fas.key  .databento.key  .oddsapi.key  .telegram.key
